{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "coverage/**",
    "data/**",
    "dist/**",
    "node_modules/**",
    "HTML/**",
    "public/version.json"
  ],
  "rules": {
    "no-console": "off",
    "no-unused-vars": "warn"
  }
}
