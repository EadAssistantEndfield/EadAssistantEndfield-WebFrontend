# Leave empty when your host exposes the backend through a same-origin `/api` proxy.
# Only point this to a full backend origin after that backend explicitly allows browser CORS.
VITE_API_BASE_URL=

# Built asset base path. Keep `/` for root deployments and set a nested path like
# `/blueprint_analysis/` when the app is served from a subdirectory.
VITE_PUBLIC_BASE_PATH=/
