# Leave empty when your host exposes the backend through a same-origin `/api` proxy.
# Only point this to a full backend origin after that backend explicitly allows browser CORS.
VITE_API_BASE_URL=

# Built asset base path. Keep `/` for root deployments and set a nested path like
# `/blueprint_analysis/` when the app is served from a subdirectory.
VITE_PUBLIC_BASE_PATH=/

# Supabase blueprint cache. Leave the key empty to disable cache reads locally.
VITE_SUPABASE_URL=https://bykzldmcqzgpmwjjpdtl.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_BLUEPRINT_CACHE_ENABLED=true

# Optional same-origin or absolute endpoint for trusted cache writes.
# Do not put service-role secrets in any VITE_ variable.
VITE_BLUEPRINT_CACHE_WRITE_ENDPOINT=
