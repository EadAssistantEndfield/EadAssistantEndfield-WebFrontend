{
  "name": "blueprint-analysis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "check:i18n": "node scripts/check-i18n.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:style": "stylelint \"src/**/*.{css,vue}\"",
    "lint:style:fix": "stylelint \"src/**/*.{css,vue}\" --fix",
    "lint:style:check": "stylelint \"src/**/*.{css,vue}\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "npm run lint && npm run check:i18n && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.2.8"
  }
}
